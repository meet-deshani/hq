# ── Database ────────────────────────────────────────────────────────────────
# HQ ships with its OWN dedicated PostgreSQL 17 container (service `hq-db` in
# docker-compose.yml). These three values configure BOTH that container and the
# app's connection to it — set them ONCE here. Never commit the real .env.
DB_USER=hq
DB_PASSWORD=change-me-to-a-strong-random-password
DB_NAME=hq
#
# DB_HOST / DB_PORT / DB_REQUIRE are injected by docker-compose.yml (hq-db:5432,
# fail-fast on). Uncomment/override ONLY when pointing HQ at an external Postgres
# instead of the bundled hq-db container:
# DB_HOST=hq-db
# DB_PORT=5432
#
# A single DATABASE_URL, if set, overrides all of the DB_* parts above:
# DATABASE_URL=postgresql://hq:<password>@hq-db:5432/hq
#
# On first startup the app creates every table and seeds the defaults — there is
# no manual schema or seed step. Data persists in the `hq_pgdata` Docker volume.

# ── Security ────────────────────────────────────────────────────────────────
# Signs the JWT session tokens. MUST be a long random string in production.
SECRET_KEY=change-me-to-a-long-random-secret
