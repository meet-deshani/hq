# ── Database ────────────────────────────────────────────────────────────────
# HQ connects to the shared dotsai PostgreSQL container over the dotsai_net
# Docker network, using its OWN database `hq` and a DEDICATED least-privilege
# role `hq` (NOT the dotsai superuser). One-time setup SQL is in docs/DATABASE.md.
#
# `postgres` here is the shared container's hostname on dotsai_net — change it if
# your container resolves under a different name (e.g. dotsai-db).
DATABASE_URL=postgresql://hq:<hq_role_password>@postgres:5432/hq
#
# The DB_* parts are an alternative to DATABASE_URL (only read when it is unset):
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=hq
# DB_PASSWORD=<hq_role_password>
# DB_NAME=hq
#
# On first startup the app creates every table and seeds the defaults — no manual
# schema/seed step. DB_REQUIRE=true (set in docker-compose.yml) makes the app fail
# fast rather than silently fall back to SQLite if the database is unreachable.

# ── Security ────────────────────────────────────────────────────────────────
# Signs the JWT session tokens. MUST be a long random string in production.
SECRET_KEY=change-me-to-a-long-random-secret

# ── AI assistant (optional) ──────────────────────────────────────────────────
# The in-app AI panel proxies to a real LLM. Until a key is set it returns a
# short "not configured" notice instead of breaking. Add the key to enable it.
# AI_PROVIDER=anthropic          # anthropic (default) | openai
# ANTHROPIC_API_KEY=sk-ant-...   # required when AI_PROVIDER=anthropic
# OPENAI_API_KEY=sk-...          # required when AI_PROVIDER=openai
# AI_MODEL=claude-3-5-sonnet-20241022   # override the model (provider-specific)
